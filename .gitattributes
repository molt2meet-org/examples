# Auto-detect text files, normalize to LF in repo
* text=auto eol=lf

# Shell scripts must be LF (otherwise they fail on Linux/macOS)
*.sh       text eol=lf

# Source files: LF for consistency
*.ts       text eol=lf
*.js       text eol=lf
*.py       text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.txt      text eol=lf

# Binary files
*.png      binary
*.jpg      binary
*.ico      binary
